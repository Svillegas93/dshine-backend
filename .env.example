# ── Base de datos ────────────────────────────────────────────
MONGODB_URI=mongodb+srv://USUARIO:PASSWORD@cluster.mongodb.net/dshine?retryWrites=true&w=majority
REDIS_URL=redis://localhost:6379

# ── Servidor ─────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
# Zona horaria del negocio (NO cambiar)
TZ=America/Bogota

# ── Seguridad ────────────────────────────────────────────────
# Origen del frontend (para CORS)
CORS_ORIGIN=http://localhost:3000
# Secreto para tokens admin (mínimo 32 caracteres)
ADMIN_SECRET=cambia_esto_por_un_secreto_seguro_de_minimo_32_chars

# ── Twilio (WhatsApp + SMS) ───────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Número Twilio para WhatsApp (Sandbox o número aprobado)
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Número Twilio para SMS fallback
TWILIO_SMS_FROM=+14155238886

# ── Email (opcional) ─────────────────────────────────────────
# Usar Resend (recomendado) o cualquier SMTP
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@dshine.com.co

# ── Admin ────────────────────────────────────────────────────
ADMIN_PHONE=+573002031782
